rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      allow read, update: if request.auth != null && request.resource.data.memberIds.hasAny([request.auth.uid]);
      allow create: if request.auth != null;
    }
    match /projects/{projectId}/{subcollection=**}/{docId} {
      allow read, write: if request.auth != null && exists(/databases/$(database)/documents/projects/$(projectId)) &&
        get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds.hasAny([request.auth.uid]);
    }
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
